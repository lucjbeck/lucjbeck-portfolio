---
/**
 * AboutAssembly — two 3-link robotic arms (bird's-eye / top-down view)
 * assemble a colored Penn shield + "PENN" in parallel.
 *
 * Arm bases are slightly inset from the canvas edges (bx=45/555, by=300),
 * with proper floor-standing base mount visuals (plate + column + pivot joint).
 * Each arm has three links (upper arm, forearm, wrist) + elbow and wrist joints.
 * The 3rd link always points toward the target for a natural "reaching" pose.
 *
 * Initial SVG positions correspond to the rest end-effector (200,300) / (400,300):
 *   Left:  base(45,300) → elbow(113,155) → wrist(120,300) → grip(200,300)
 *   Right: base(555,300) → elbow(487,155) → wrist(480,300) → grip(400,300)
 *
 * Logic in ../scripts/about.ts. Mount id: #about-assembly.
 */
const VB   = 600;
const ticks = Array.from({ length: 9 }, (_, i) => 60 + i * 60);
---

<div id="about-assembly" class="ab" role="img"
  aria-label="Two 3-link robotic arms (top-down view) assembling a University of Pennsylvania shield">
  <svg class="ab-svg" viewBox={`0 0 ${VB} ${VB}`} fill="none" aria-hidden="true">
    <rect class="ab-surface" x="20" y="20" width="560" height="560" rx="6" />
    {ticks.map((t) => (
      <g class="ab-grid">
        <line x1={t} y1="20" x2={t} y2="580" />
        <line x1="20" y1={t} x2="580" y2={t} />
      </g>
    ))}

    <!-- pieces created by the script -->
    <g data-pieces />

    <!-- ── LEFT ARM — base at (90, 300) — well clear of shield left edge (x=180) ─── -->
    <rect class="ab-base-plate" x="61"  y="292" width="58" height="20" rx="5" />
    <rect class="ab-base-col"   x="78"  y="272" width="24" height="22" rx="3" />
    <circle class="ab-base-pivot" cx="90" cy="300" r="9" />

    <g class="ab-arm-2d" data-arm="0">
      <!-- Approximate initial pose: end-effector reaching toward center-top -->
      <line class="ab-ua" data-ua  x1="90"  y1="300" x2="68"  y2="185" />
      <circle class="ab-ejoint" data-ej cx="68"  cy="185" r="6" />
      <line class="ab-fa" data-fa  x1="68"  y1="185" x2="130" y2="231" />
      <circle class="ab-wjoint" data-wj cx="130" cy="231" r="4" />
      <line class="ab-wr" data-wr  x1="130" y1="231" x2="150" y2="240" />
      <g class="ab-grip" data-grip transform="translate(150 240)">
        <circle class="ab-grip-ring" r="8" />
        <line class="ab-grip-jaw" x1="-5" y1="-8" x2="5" y2="-8" />
        <line class="ab-grip-jaw" x1="-5" y1="8"  x2="5" y2="8" />
      </g>
    </g>

    <!-- ── RIGHT ARM — base at (510, 300) — well clear of shield right edge (x=420) ─ -->
    <rect class="ab-base-plate" x="481" y="292" width="58" height="20" rx="5" />
    <rect class="ab-base-col"   x="498" y="272" width="24" height="22" rx="3" />
    <circle class="ab-base-pivot" cx="510" cy="300" r="9" />

    <g class="ab-arm-2d" data-arm="1">
      <line class="ab-ua" data-ua  x1="510" y1="300" x2="532" y2="185" />
      <circle class="ab-ejoint" data-ej cx="532" cy="185" r="6" />
      <line class="ab-fa" data-fa  x1="532" y1="185" x2="470" y2="231" />
      <circle class="ab-wjoint" data-wj cx="470" cy="231" r="4" />
      <line class="ab-wr" data-wr  x1="470" y1="231" x2="450" y2="240" />
      <g class="ab-grip" data-grip transform="translate(450 240)">
        <circle class="ab-grip-ring" r="8" />
        <line class="ab-grip-jaw" x1="-5" y1="-8" x2="5" y2="-8" />
        <line class="ab-grip-jaw" x1="-5" y1="8"  x2="5" y2="8" />
      </g>
    </g>
  </svg>
</div>

<style>
  .ab {
    width: 100%;
    max-width: 500px;
    margin-inline: auto;
    /* subtle red glow as a box-shadow (a `filter` would clip arms that swing
       past the panel edge to its filter region). */
    box-shadow: 0 0 26px rgba(230, 57, 70, 0.06);
  }
  /* Let the arms paint past the panel edge instead of being clipped to the
     viewBox — they ride over the dark page background and stay visible. */
  .ab-svg { width: 100%; height: auto; display: block; overflow: visible; }
  /* On phones the figure is full-width, so an overflowing arm would bleed to the
     screen edge. Clip to the panel there (no page overflow). Desktop unchanged. */
  @media (max-width: 860px) {
    .ab-svg { overflow: hidden; }
  }
  .ab-surface { fill: var(--c-bg-elev); stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .ab-grid line { stroke: var(--c-hairline); stroke-width: 1; }

  :global(.ab-letter) {
    fill: #011F5B;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 84px;
    text-anchor: middle;
    dominant-baseline: central;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* ── floor-standing base mount ── */
  /* heavy horizontal plate — sits on the work surface */
  .ab-base-plate {
    fill: var(--c-bg-elev-2);
    stroke: var(--c-text-muted);
    stroke-width: 1.5;
  }
  /* vertical column rising from the plate to the shoulder joint */
  .ab-base-col {
    fill: var(--c-bg-elev-2);
    stroke: var(--c-text-faint);
    stroke-width: 1;
  }
  /* shoulder joint pivot (rotation axis at top of column) */
  .ab-base-pivot {
    fill: var(--c-bg);
    stroke: var(--c-text-muted);
    stroke-width: 2.5;
  }

  /* ── arm links — shadow goes lower-right (matching block depth direction) ── */
  .ab-ua {
    stroke: var(--c-text-muted);
    stroke-width: 10;
    stroke-linecap: round;
    filter: drop-shadow(4px 4px 5px rgba(0,0,0,0.55));
  }
  .ab-fa {
    stroke: var(--c-text-muted);
    stroke-width: 8;
    stroke-linecap: round;
    filter: drop-shadow(4px 4px 4px rgba(0,0,0,0.4));
  }
  .ab-wr {
    stroke: var(--c-text-muted);
    stroke-width: 5;
    stroke-linecap: round;
    filter: drop-shadow(3px 3px 3px rgba(0,0,0,0.3));
  }

  /* ── joints ── */
  .ab-ejoint {
    fill: var(--c-bg);
    stroke: var(--c-text-faint);
    stroke-width: 2;
  }
  .ab-wjoint {
    fill: var(--c-bg);
    stroke: var(--c-text-faint);
    stroke-width: 1.5;
  }

  /* ── gripper ── */
  .ab-grip-ring {
    fill: var(--c-bg);
    stroke: var(--c-text-faint);
    stroke-width: 2.5;
  }
  .ab-grip-jaw {
    stroke: var(--c-text-faint);
    stroke-width: 2.5;
    stroke-linecap: round;
  }
  .ab-grip.is-gripping .ab-grip-ring,
  .ab-grip.is-gripping .ab-grip-jaw {
    stroke: var(--c-accent);
  }
</style>

<script>
  import { initAboutAssembly } from "../scripts/about.ts";
  initAboutAssembly();
</script>
