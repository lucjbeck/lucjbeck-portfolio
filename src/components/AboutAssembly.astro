---
/**
 * AboutAssembly — TWO gantry cranes (each: a carriage sliding on a ceiling rail +
 * a vertical hoist with a gripper = X and Y prismatic DOF) assemble, in parallel,
 * a colored Penn shield on top and the word PENN below. Cranes stay fully in frame.
 * Pieces are already in their Penn colors (navy / red / white) and lock in with a
 * seeded slight rotation/offset. This #about exhibit is the ONLY place on the site
 * that uses color beyond the red accent. Logic in ../scripts/about.ts.
 * Plays on scroll-in; reduced-motion shows the finished result at rest.
 *
 * Mount id: #about-assembly.
 */
const VB = 600;
const ticks = Array.from({ length: 9 }, (_, i) => 60 + i * 60);
---

<div id="about-assembly" class="ab" role="img" aria-label="Two gantry cranes assembling a colored University of Pennsylvania shield and the word PENN from scattered colored blocks">
  <svg class="ab-svg" viewBox={`0 0 ${VB} ${VB}`} fill="none" aria-hidden="true">
    <rect class="ab-surface" x="20" y="20" width="560" height="560" rx="6"></rect>
    {ticks.map((t) => (
      <g class="ab-grid"><line x1={t} y1="20" x2={t} y2="580" /><line x1="20" y1={t} x2="580" y2={t} /></g>
    ))}

    <!-- ceiling rail -->
    <line class="ab-rail" x1="34" y1="38" x2={VB - 34} y2="38"></line>
    <line class="ab-rail2" x1="34" y1="42" x2={VB - 34} y2="42"></line>

    <!-- pieces created by the script -->
    <g data-pieces></g>

    <!-- two gantry cranes (left half + right half) -->
    <g class="ab-arm" data-arm="0" data-restx="200" data-min="110" data-max="290">
      <rect class="ab-cart" data-cart x="182" y="28" width="36" height="16" rx="3"></rect>
      <circle class="ab-rollsm" data-roll cx="190" cy="40" r="3"></circle>
      <circle class="ab-rollsm" data-roll2 cx="210" cy="40" r="3"></circle>
      <line class="ab-hoist" data-hoist x1="200" y1="44" x2="200" y2="300"></line>
      <g class="ab-grip" data-grip transform="translate(200 300)">
        <circle class="ab-grip-ring" r="9"></circle>
        <line class="ab-grip-jaw" x1="-9" y1="2" x2="-9" y2="11"></line>
        <line class="ab-grip-jaw" x1="9" y1="2" x2="9" y2="11"></line>
      </g>
    </g>
    <g class="ab-arm" data-arm="1" data-restx="400" data-min="310" data-max="490">
      <rect class="ab-cart" data-cart x="382" y="28" width="36" height="16" rx="3"></rect>
      <circle class="ab-rollsm" data-roll cx="390" cy="40" r="3"></circle>
      <circle class="ab-rollsm" data-roll2 cx="410" cy="40" r="3"></circle>
      <line class="ab-hoist" data-hoist x1="400" y1="44" x2="400" y2="300"></line>
      <g class="ab-grip" data-grip transform="translate(400 300)">
        <circle class="ab-grip-ring" r="9"></circle>
        <line class="ab-grip-jaw" x1="-9" y1="2" x2="-9" y2="11"></line>
        <line class="ab-grip-jaw" x1="9" y1="2" x2="9" y2="11"></line>
      </g>
    </g>
  </svg>
</div>

<style>
  .ab { width: 100%; max-width: 500px; margin-inline: auto; filter: drop-shadow(0 0 26px rgba(230, 57, 70, 0.06)); }
  .ab-svg { width: 100%; height: auto; display: block; }
  .ab-surface { fill: var(--c-bg-elev); stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .ab-grid line { stroke: var(--c-hairline); stroke-width: 1; }
  .ab-rail { stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .ab-rail2 { stroke: var(--c-hairline); stroke-width: 1.5; }

  /* pieces carry their Penn color the whole time (color only inside #about). */
  :global(.ab-pc) {
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
  }
  :global(.ab-pc.navy) { fill: #011F5B; stroke: #012a7a; }
  :global(.ab-pc.red)  { fill: #990000; stroke: #b51111; }
  :global(.ab-pc.white){ fill: #EDEDED; stroke: #ffffff; }
  :global(.ab-letter) {
    fill: #011F5B;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 84px;
    text-anchor: middle;
    dominant-baseline: central;
    transform-box: fill-box;
    transform-origin: center;
  }

  .ab-cart { fill: var(--c-bg-elev-2); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .ab-rollsm { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .ab-hoist { stroke: var(--c-text-muted); stroke-width: 4; stroke-linecap: round; }
  .ab-grip-ring { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 2.5; }
  .ab-grip-jaw { stroke: var(--c-text-faint); stroke-width: 2.5; stroke-linecap: round; }
  .ab-grip.is-gripping .ab-grip-ring,
  .ab-grip.is-gripping .ab-grip-jaw { stroke: var(--c-accent); }
</style>

<script>
  import { initAboutAssembly } from "../scripts/about.ts";
  initAboutAssembly();
</script>
