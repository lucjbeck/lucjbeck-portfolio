---
/**
 * AboutAssembly — top-down (bird's-eye) assembly animation for the About section.
 * A 2-link articulated arm (closed-form IK in ../scripts/about.ts) picks up
 * scattered geometric pieces and assembles them into a blocky, low-poly homage to
 * the University of Pennsylvania shield. Placed pieces lock in the red accent.
 * SVG + anime.js v4 spring easing; deterministic targets so it always forms.
 *
 * Mount id: #about-assembly. Geometry mirrored in the script.
 */
const VB = 600;
const CELL = 56;

// Shield target layout (rows tapering 4,4,3,2,1 -> flat top, point bottom).
const targets: [number, number][] = [
  [210, 180], [270, 180], [330, 180], [390, 180],
  [210, 240], [270, 240], [330, 240], [390, 240],
  [240, 300], [300, 300], [360, 300],
  [270, 360], [330, 360],
  [300, 420],
];
// Deterministic scattered start positions, all within the arm's reach.
const starts: [number, number][] = [
  [120, 210], [480, 210], [95, 340], [505, 340], [160, 470], [440, 470],
  [250, 160], [350, 160], [185, 300], [415, 300], [300, 170], [130, 420],
  [470, 420], [300, 470],
];
const ticks = Array.from({ length: 9 }, (_, i) => 60 + i * 60);
---

<div id="about-assembly" class="ab" role="img" aria-label="A robotic arm assembling scattered geometric pieces into a blocky University of Pennsylvania shield">
  <svg class="ab-svg" viewBox={`0 0 ${VB} ${VB}`} fill="none" aria-hidden="true">
    <!-- work surface -->
    <rect class="ab-surface" x="20" y="20" width="560" height="560" rx="6"></rect>
    {ticks.map((t) => (
      <g class="ab-grid">
        <line x1={t} y1="20" x2={t} y2="580" />
        <line x1="20" y1={t} x2="580" y2={t} />
      </g>
    ))}

    <!-- pieces (start scattered; the script carries each to its target) -->
    {
      starts.map((s, i) => (
        <rect
          class="ab-piece"
          data-piece
          data-sx={s[0]}
          data-sy={s[1]}
          data-tx={targets[i][0]}
          data-ty={targets[i][1]}
          x={-CELL / 2}
          y={-CELL / 2}
          width={CELL}
          height={CELL}
          rx="3"
          transform={`translate(${s[0]} ${s[1]})`}
        />
      ))
    }

    <!-- top-down 2-link arm, base anchored at the bottom edge -->
    <g class="ab-arm" data-arm>
      <line class="ab-link" data-upper x1="300" y1="600" x2="300" y2="350"></line>
      <line class="ab-link" data-fore x1="300" y1="350" x2="300" y2="110"></line>
      <circle class="ab-joint" cx="300" cy="600" r="11"></circle>
      <circle class="ab-joint" data-elbow cx="300" cy="350" r="8"></circle>
      <g class="ab-grip" data-grip transform="translate(300 110)">
        <circle class="ab-grip-ring" r="10"></circle>
        <line class="ab-grip-jaw" x1="-10" y1="0" x2="-16" y2="0"></line>
        <line class="ab-grip-jaw" x1="10" y1="0" x2="16" y2="0"></line>
      </g>
    </g>
  </svg>
</div>

<style>
  .ab {
    width: 100%;
    max-width: 520px;
    margin-inline: auto;
    filter: drop-shadow(0 0 26px rgba(230, 57, 70, 0.06));
  }
  .ab-svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .ab-surface {
    fill: var(--c-bg-elev);
    stroke: var(--c-hairline-strong);
    stroke-width: 1.5;
  }
  .ab-grid line {
    stroke: var(--c-hairline);
    stroke-width: 1;
  }

  .ab-piece {
    fill: var(--c-bg-elev-2);
    stroke: var(--c-text-muted);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
  }
  /* a placed piece locks into the accent */
  .ab-piece.is-placed {
    fill: var(--c-accent-dim);
    stroke: var(--c-accent);
  }

  .ab-link {
    stroke: var(--c-text-muted);
    stroke-width: 9;
    stroke-linecap: round;
  }
  .ab-joint {
    fill: var(--c-bg);
    stroke: var(--c-text-faint);
    stroke-width: 2;
  }
  .ab-grip-ring {
    fill: none;
    stroke: var(--c-text-faint);
    stroke-width: 2.5;
  }
  .ab-grip-jaw {
    stroke: var(--c-text-faint);
    stroke-width: 2.5;
    stroke-linecap: round;
  }
  /* gripper engaged */
  .ab-grip.is-gripping .ab-grip-ring,
  .ab-grip.is-gripping .ab-grip-jaw {
    stroke: var(--c-accent);
  }
</style>

<script>
  import { initAboutAssembly } from "../scripts/about.ts";
  initAboutAssembly();
</script>
