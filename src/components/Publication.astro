---
/**
 * Publication — a single publication credit row inside a ResearchEntry.
 *
 * Props:
 *   role: string                 // e.g. "First author", "Patient perspective"
 *   venue: string                // journal / venue name
 *   status?: string              // e.g. "ACCEPTED — AWAITING PUBLICATION"
 *   href?: string                // article URL (omit when not yet available)
 *   linkLabel?: string           // text for the link (default "Read")
 *   abstract?: string            // optional abstract block below the title
 *
 * Slots: default — the citation / title text.
 */
interface Props {
  role: string;
  venue: string;
  status?: string;
  href?: string;
  linkLabel?: string;
  abstract?: string;
}

const {
  role,
  venue,
  status,
  href,
  linkLabel = "Read",
  abstract,
} = Astro.props;
---

<article class="pub" data-reveal>
  <p class="pub__tags">
    <span class="pub__role">{role}</span>
    <span class="pub__venue">{venue}</span>
  </p>
  {status && <p class="pub__status">{status}</p>}
  <p class="pub__title"><slot /></p>
  {abstract && (
    <div class="pub__abstract">
      <span class="pub__abstract-label" aria-hidden="true">Abstract</span>
      {abstract}
    </div>
  )}
  {
    href ? (
      <a class="pub__link" href={href} target="_blank" rel="noopener noreferrer">
        {linkLabel}
        <span aria-hidden="true"> ↗</span>
      </a>
    ) : null
  }
</article>

<style>
  .pub {
    padding-block: var(--space-4);
    border-top: var(--border);
  }
  .pub:first-of-type {
    border-top: none;
    padding-top: 0;
  }

  .pub__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    margin-bottom: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }
  .pub__role {
    color: var(--c-accent);
  }
  .pub__venue {
    color: var(--c-text-faint);
  }

  .pub__title {
    color: var(--c-text);
    margin-bottom: var(--space-2);
  }

  .pub__status {
    margin-bottom: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--c-accent);
  }

  .pub__abstract {
    margin-top: var(--space-4);
    padding-left: var(--space-5);
    border-left: 2px solid var(--c-accent-dim);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
  }
  .pub__abstract-label {
    display: block;
    margin-bottom: var(--space-2);
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  .pub__link {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
  }
</style>
