---
/**
 * RobotArm.astro — Engineering section: a working two-link pick-and-place arm.
 * Driven by inverse kinematics (../scripts/robotarm.ts): the arm reaches a feeder,
 * the gripper closes on a block, carries it via real forward kinematics, and
 * stacks it on the left; after a few it ships the stack and repeats. SVG attribute
 * transforms (rotate about explicit pivots) give correct nested kinematics.
 * SSR renders a posed static arm for reduced-motion / no-JS.
 *
 * Mount id: #robot-arm. Geometry pivots are mirrored in the script.
 */
const VW = 360;
const VH = 300;
---

<div id="robot-arm" class="ra" role="img" aria-label="Two-link robotic arm performing a pick-and-place cycle: it grips blocks from a feeder and stacks them">
  <svg class="ra-svg" viewBox={`0 0 ${VW} ${VH}`} fill="none" aria-hidden="true">
    <line class="ra-ground" x1="30" y1="272" x2="330" y2="272"></line>
    <!-- feeder (right) and stack pad (left) -->
    <rect class="ra-pad" x="270" y="264" width="40" height="8" rx="2"></rect>
    <rect class="ra-pad" x="54" y="264" width="52" height="8" rx="2"></rect>

    <!-- payload blocks (positioned by the script) -->
    <g data-blocks>
      <rect class="ra-block" data-block x="0" y="0" width="26" height="15" rx="2" style="opacity:0"></rect>
      <rect class="ra-block" data-block x="0" y="0" width="26" height="15" rx="2" style="opacity:0"></rect>
      <rect class="ra-block" data-block x="0" y="0" width="26" height="15" rx="2" style="opacity:0"></rect>
      <rect class="ra-block ra-block--hot" data-block x="0" y="0" width="26" height="15" rx="2" style="opacity:0"></rect>
    </g>

    <!-- arm: base pivot (180,256) -->
    <polygon class="ra-base" points="158,272 202,272 194,250 166,250"></polygon>
    <g class="ra-shoulder" data-shoulder transform="rotate(8 180 256)">
      <rect class="ra-link" x="174" y="162" width="12" height="96" rx="6"></rect>
      <circle class="ra-joint" cx="180" cy="256" r="7"></circle>
      <g class="ra-elbow" data-elbow transform="rotate(-16 180 162)">
        <rect class="ra-link" x="175" y="66" width="10" height="98" rx="5"></rect>
        <circle class="ra-joint" cx="180" cy="162" r="6"></circle>
        <g class="ra-gripper" data-gripper>
          <line class="ra-prong" x1="171" y1="78" x2="171" y2="62"></line>
          <line class="ra-prong" x1="189" y1="78" x2="189" y2="62"></line>
          <line class="ra-knuckle" x1="171" y1="78" x2="189" y2="78"></line>
        </g>
      </g>
    </g>
  </svg>
</div>

<style>
  .ra {
    width: 100%;
    max-width: 360px;
    margin-inline: auto;
    filter: drop-shadow(0 0 24px rgba(230, 57, 70, 0.07));
  }
  .ra-svg { width: 100%; height: auto; overflow: visible; }

  .ra-ground { stroke: var(--c-hairline-strong); stroke-width: 1.5; stroke-dasharray: 4 6; }
  .ra-pad { fill: var(--c-bg-elev); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .ra-base { fill: var(--c-bg-elev); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .ra-link { fill: var(--c-bg-elev-2); stroke: var(--c-text-muted); stroke-width: 1.5; }
  .ra-joint { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .ra-prong, .ra-knuckle { stroke: var(--c-accent); stroke-width: 3; stroke-linecap: round; }

  .ra-block {
    fill: var(--c-bg-elev-2);
    stroke: var(--c-text-muted);
    stroke-width: 1.5;
  }
  .ra-block--hot { stroke: var(--c-accent); fill: var(--c-accent-dim); }
</style>

<script>
  import { initRobotArm } from "../scripts/robotarm.ts";
  initRobotArm();
</script>
