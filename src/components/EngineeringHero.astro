---
/**
 * EngineeringHero.astro — landing signature: an overhead gantry assembly line.
 * A carriage rides a ceiling rail (a prismatic DOF) and a two-link arm hangs from
 * it, so the whole thing obeys a real gantry kinematic and never reaches up from
 * the floor. It picks parts off a physics conveyor and assembles ONE OF THREE
 * products in rotation (rover, drone, robot); the finished unit rolls off and the
 * next is built. Driven by ../scripts/engineering.ts. SSR shows a static frame.
 *
 * Mount id: #eng-hero. Geometry mirrored in the script.
 */
const VW = 560;
const VH = 320;
const RAIL_Y = 40;
const BELT_Y = 276;
const rollers = [60, 180, 300, 420, 510];
---

<div id="eng-hero" class="eng" role="img" aria-label="Overhead gantry assembly line: a ceiling-mounted arm picks parts off a conveyor and assembles a product, which rolls away">
  <svg class="eng-svg" viewBox={`0 0 ${VW} ${VH}`} fill="none" aria-hidden="true">
    <!-- ceiling rail -->
    <line class="eng-rail" x1="20" y1={RAIL_Y} x2={VW - 20} y2={RAIL_Y}></line>
    <line class="eng-rail-2" x1="20" y1={RAIL_Y + 4} x2={VW - 20} y2={RAIL_Y + 4}></line>

    <!-- conveyor + rollers -->
    <rect class="eng-belt" x="16" y={BELT_Y} width={VW - 32} height="10" rx="5"></rect>
    {rollers.map((rx) => (
      <g class="eng-roller" data-roller transform={`rotate(0 ${rx} ${BELT_Y + 16})`}>
        <circle cx={rx} cy={BELT_Y + 16} r="14" />
        <line x1={rx} y1={BELT_Y + 2} x2={rx} y2={BELT_Y + 30} />
        <line x1={rx - 14} y1={BELT_Y + 16} x2={rx + 14} y2={BELT_Y + 16} />
      </g>
    ))}

    <!-- ambient parts flowing on the belt (belt physics) -->
    <g data-amb-layer>
      {Array.from({ length: 6 }).map(() => (
        <rect class="eng-amb" data-amb x="0" y="0" width="18" height="13" rx="2" style="opacity:0" />
      ))}
    </g>

    <!-- product parts created dynamically by the script -->
    <g data-parts></g>

    <!-- gantry carriage on the rail (slides horizontally), arm hangs below.
         Rest pivot x = 280; the script translates the carriage along the rail. -->
    <g class="eng-carriage" data-carriage transform="translate(0 0)">
      <rect class="eng-cart" x="262" y="30" width="36" height="18" rx="3"></rect>
      <circle class="eng-roller-sm" cx="270" cy="40" r="3"></circle>
      <circle class="eng-roller-sm" cx="290" cy="40" r="3"></circle>
      <g class="eng-sh" data-arm-sh transform="rotate(0 280 54)">
        <rect class="eng-link" x="274" y="54" width="12" height="108" rx="6"></rect>
        <circle class="eng-joint" cx="280" cy="54" r="6"></circle>
        <g class="eng-el" data-arm-el transform="rotate(0 280 162)">
          <rect class="eng-link" x="275" y="162" width="10" height="104" rx="5"></rect>
          <circle class="eng-joint" cx="280" cy="162" r="5"></circle>
          <g class="eng-grip" data-arm-grip>
            <line class="eng-prong" x1="272" y1="266" x2="272" y2="280"></line>
            <line class="eng-prong" x1="288" y1="266" x2="288" y2="280"></line>
            <line class="eng-knuckle" x1="272" y1="266" x2="288" y2="266"></line>
          </g>
        </g>
      </g>
    </g>
  </svg>
</div>

<style>
  .eng { width: 100%; max-width: 640px; margin-inline: auto; filter: drop-shadow(0 0 26px rgba(230, 57, 70, 0.07)); }
  .eng-svg { width: 100%; height: auto; overflow: visible; }

  .eng-rail { stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .eng-rail-2 { stroke: var(--c-hairline); stroke-width: 1.5; }
  .eng-belt { fill: var(--c-bg-elev); stroke: var(--c-hairline-strong); stroke-width: 1; }
  .eng-roller circle { fill: none; stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-roller line { stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .eng-roller-sm { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.5; }

  .eng-amb { fill: var(--c-bg-elev-2); stroke: var(--c-hairline-strong); stroke-width: 1; }

  .eng-cart { fill: var(--c-bg-elev-2); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-link { fill: var(--c-bg-elev-2); stroke: var(--c-text-muted); stroke-width: 1.5; }
  .eng-joint { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-prong, .eng-knuckle { stroke: var(--c-accent); stroke-width: 3; stroke-linecap: round; }

  :global(.eng-part) { fill: var(--c-bg-elev-2); stroke: var(--c-text-muted); stroke-width: 1.5; }
  :global(.eng-part-hot) { fill: var(--c-accent-dim); stroke: var(--c-accent); stroke-width: 1.5; }
  :global(.eng-ant line) { stroke: var(--c-accent); stroke-width: 2.5; stroke-linecap: round; }
  :global(.eng-ant circle) { fill: var(--c-accent); }
</style>

<script>
  import { initEngineering } from "../scripts/engineering.ts";
  initEngineering();
</script>
