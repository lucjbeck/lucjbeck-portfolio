---
/**
 * EngineeringHero.astro — landing signature: a legible assembly cell.
 * Flow reads left to right: raw parts ride the INPUT belt in from the left, a
 * ceiling-slider arm picks them and assembles a product on the central station,
 * and the finished unit leaves on the OUTPUT belt to the right. Parts never go
 * back onto the belt they came from. Minimal, one accent. Driven by
 * ../scripts/engineering.ts. SSR shows a static frame.
 *
 * Mount id: #eng-hero. Geometry mirrored in the script.
 */
const VW = 560;
const VH = 320;
const RAIL_Y = 40;
const BELT_Y = 276;
const inRollers = [44, 124, 204];
const outRollers = [356, 436, 516];
---

<div id="eng-hero" class="eng" role="img" aria-label="Assembly cell: raw parts arrive on an input conveyor at left, an arm assembles a product on a central station, and the finished unit leaves on the output conveyor at right">
  <svg class="eng-svg" viewBox={`0 0 ${VW} ${VH}`} fill="none" aria-hidden="true">
    <!-- ceiling rail (gantry slider) -->
    <line class="eng-rail" x1="20" y1={RAIL_Y} x2={VW - 20} y2={RAIL_Y}></line>
    <line class="eng-rail-2" x1="20" y1={RAIL_Y + 4} x2={VW - 20} y2={RAIL_Y + 4}></line>

    <!-- input belt (left) -->
    <rect class="eng-belt" x="8" y={BELT_Y} width="228" height="10" rx="5"></rect>
    {inRollers.map((rx) => (
      <g class="eng-roller" data-roller transform={`rotate(0 ${rx} ${BELT_Y + 16})`}>
        <circle cx={rx} cy={BELT_Y + 16} r="14" /><line x1={rx} y1={BELT_Y + 2} x2={rx} y2={BELT_Y + 30} /><line x1={rx - 14} y1={BELT_Y + 16} x2={rx + 14} y2={BELT_Y + 16} />
      </g>
    ))}
    <text class="eng-tag" x="12" y={BELT_Y + 44}>IN</text>

    <!-- output belt (right) -->
    <rect class="eng-belt" x="324" y={BELT_Y} width="228" height="10" rx="5"></rect>
    {outRollers.map((rx) => (
      <g class="eng-roller" data-roller transform={`rotate(0 ${rx} ${BELT_Y + 16})`}>
        <circle cx={rx} cy={BELT_Y + 16} r="14" /><line x1={rx} y1={BELT_Y + 2} x2={rx} y2={BELT_Y + 30} /><line x1={rx - 14} y1={BELT_Y + 16} x2={rx + 14} y2={BELT_Y + 16} />
      </g>
    ))}
    <text class="eng-tag" x={VW - 36} y={BELT_Y + 44}>OUT</text>

    <!-- central assembly station -->
    <g class="eng-stand">
      <rect x="272" y="250" width="56" height="6" rx="2"></rect>
      <line x1="282" y1="256" x2="282" y2="276"></line>
      <line x1="318" y1="256" x2="318" y2="276"></line>
    </g>

    <!-- product parts (created dynamically by the script) -->
    <g data-parts></g>

    <!-- gantry carriage + hanging arm; rest pivot x = 300 -->
    <g class="eng-carriage" data-carriage transform="translate(0 0)">
      <rect class="eng-cart" x="282" y="30" width="36" height="18" rx="3"></rect>
      <circle class="eng-roller-sm" cx="290" cy="40" r="3"></circle>
      <circle class="eng-roller-sm" cx="310" cy="40" r="3"></circle>
      <g class="eng-sh" data-arm-sh transform="rotate(0 300 54)">
        <rect class="eng-link" x="294" y="54" width="12" height="108" rx="6"></rect>
        <circle class="eng-joint" cx="300" cy="54" r="6"></circle>
        <g class="eng-el" data-arm-el transform="rotate(0 300 162)">
          <rect class="eng-link" x="295" y="162" width="10" height="104" rx="5"></rect>
          <circle class="eng-joint" cx="300" cy="162" r="5"></circle>
        </g>
      </g>
    </g>

    <!-- suction end-effector: separate group kept upright, descends onto parts -->
    <g class="eng-hand" data-arm-hand transform="translate(300 251)">
      <rect class="eng-headmount" x="-11" y="-3" width="22" height="6" rx="1"></rect>
      <path class="eng-pad" d="M-8,3 L8,3 L5,12 L-5,12 Z"></path>
    </g>
  </svg>
</div>

<style>
  .eng { width: 100%; max-width: 640px; margin-inline: auto; filter: drop-shadow(0 0 26px rgba(230, 57, 70, 0.07)); }
  .eng-svg { width: 100%; height: auto; overflow: visible; }

  .eng-rail { stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .eng-rail-2 { stroke: var(--c-hairline); stroke-width: 1.5; }
  .eng-belt { fill: var(--c-bg-elev); stroke: var(--c-hairline-strong); stroke-width: 1; }
  .eng-roller circle { fill: none; stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-roller line { stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .eng-roller-sm { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-stand rect { fill: var(--c-bg-elev); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-stand line { stroke: var(--c-hairline); stroke-width: 1.5; }
  .eng-tag { fill: var(--c-text-faint); font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.14em; }

  .eng-cart { fill: var(--c-bg-elev-2); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-link { fill: var(--c-bg-elev-2); stroke: var(--c-text-muted); stroke-width: 1.5; }
  .eng-joint { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .eng-headmount { fill: var(--c-bg-elev-2); stroke: var(--c-text-muted); stroke-width: 1.5; }
  .eng-pad { fill: var(--c-accent-dim); stroke: var(--c-accent); stroke-width: 1.5; }

  :global(.eng-part) { fill: var(--c-bg-elev-2); stroke: var(--c-text-muted); stroke-width: 1.5; }
  :global(.eng-part-hot) { fill: var(--c-accent-dim); stroke: var(--c-accent); stroke-width: 1.5; }
  :global(.eng-eye) { fill: var(--c-accent); stroke: none; }
  :global(.eng-mini) { stroke: var(--c-text-muted); stroke-width: 2.5; stroke-linecap: round; fill: none; }
  :global(.eng-mini-joint) { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.2; }
  :global(.eng-mini-grip) { stroke: var(--c-accent); stroke-width: 2.5; stroke-linecap: round; }
  :global(.eng-ant line) { stroke: var(--c-accent); stroke-width: 2.5; stroke-linecap: round; }
  :global(.eng-ant circle) { fill: var(--c-accent); }
</style>

<script>
  import { initEngineering } from "../scripts/engineering.ts";
  initEngineering();
</script>
