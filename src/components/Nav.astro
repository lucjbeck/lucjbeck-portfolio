---
/**
 * Nav — datasheet-style top bar. A mono wordmark cell on the left and a few
 * hairline-divided anchor cells on the right. Not a generic centered sticky bar.
 * Keyboard accessible with visible focus (inherited from global.css).
 */
const links = [
  { href: "#top", label: "Home", index: "00" },
  { href: "#about", label: "About", index: "01" },
  { href: "#education", label: "Education", index: "02" },
  { href: "#engineering", label: "Engineering", index: "03" },
  { href: "#research", label: "Research", index: "04" },
  { href: "#experience", label: "Experience", index: "05" },
  { href: "#contact", label: "Contact", index: "06" },
];
---

<header class="nav">
  <a class="nav__wordmark" href="#top">
    <span class="nav__mark" aria-hidden="true">
      <span class="nav__mark-num">19</span>
      <span class="nav__mark-sym">Lb</span>
      <span class="nav__mark-mass">'29</span>
    </span>
    <span class="nav__name">Luc Beck</span>
  </a>

  <button class="nav__toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="nav-menu">
    <span class="nav__toggle-bar" aria-hidden="true"></span>
    <span class="nav__toggle-bar" aria-hidden="true"></span>
    <span class="nav__toggle-bar" aria-hidden="true"></span>
  </button>

  <nav id="nav-menu" class="nav__links" aria-label="Primary">
    <ul role="list" class="nav__list">
      {
        links.map((link) => (
          <li class="nav__item">
            <a class="nav__link" href={link.href} data-spring>
              <span class="nav__index" aria-hidden="true">{link.index}</span>
              <span class="nav__label">{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: var(--space-4);
    padding-inline: var(--gutter);
    border-bottom: var(--border);
    background: color-mix(in srgb, var(--c-bg) 86%, transparent);
    backdrop-filter: blur(8px);
  }

  .nav__wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-3);
    color: var(--c-text);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }
  .nav__wordmark:hover {
    color: var(--c-text);
    text-decoration: none;
  }

  /* periodic-table element tile */
  .nav__mark {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 3.3rem;
    height: 3.3rem;
    border: 1px solid var(--c-hairline-strong);
    border-radius: var(--r-sm);
    background: var(--c-bg-elev);
    overflow: hidden;
  }
  .nav__mark-num {
    position: absolute;
    top: 3px;
    left: 4px;
    font-size: 0.56rem;
    line-height: 1;
    letter-spacing: -0.08em;
    color: var(--c-text-faint);
    font-variant-numeric: tabular-nums;
  }
  .nav__mark-mass {
    position: absolute;
    bottom: 3px;
    right: 4px;
    font-size: 0.56rem;
    line-height: 1;
    letter-spacing: -0.08em;
    color: var(--c-text-faint);
    font-variant-numeric: tabular-nums;
  }
  .nav__mark-sym {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: 1.15rem;
    line-height: 1;
    color: var(--c-accent);
    letter-spacing: 0;
    text-transform: none;
  }

  .nav__name {
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  /* hamburger toggle — hidden on desktop, shown at the mobile breakpoint */
  .nav__toggle {
    display: none;          /* shown at the mobile breakpoint */
    align-self: center;     /* vertically centre the button in the tall bar */
    flex-direction: column;
    align-items: center;    /* centre the bars horizontally */
    justify-content: center;/* centre the bars vertically */
    gap: 5px;
    width: 44px;
    height: 44px;
    flex: 0 0 auto;
    padding: 0;
    background: none;
    border: 1px solid var(--c-hairline-strong);
    border-radius: var(--r-sm);
    cursor: pointer;
  }
  .nav__toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--c-text);
    transition: transform var(--dur-fast) var(--ease-out),
      opacity var(--dur-fast) var(--ease-out);
  }

  .nav__links {
    display: flex;
  }

  .nav__list {
    display: flex;
    align-items: stretch;
    margin: 0;
  }

  .nav__item {
    display: flex;
    border-left: var(--border);
  }

  .nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding-inline: var(--space-4);
    color: var(--c-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .nav__link:hover {
    color: var(--c-text);
    background: var(--c-bg-elev);
    text-decoration: none;
  }

  .nav__index {
    color: var(--c-accent);
    font-size: var(--fs-micro);
  }

  /* ── Mobile: collapse the link row into a hamburger dropdown ──────────── */
  @media (max-width: 860px) {
    .nav__toggle {
      display: flex;
    }

    /* dropdown panel anchored under the bar; doesn't push content */
    .nav__links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: color-mix(in srgb, var(--c-bg) 96%, transparent);
      backdrop-filter: blur(8px);
      border-bottom: var(--border);
      max-height: calc(100dvh - 100%);
      overflow-y: auto;
      visibility: hidden;
      opacity: 0;
      transform: translateY(-6px);
      transition: opacity var(--dur-fast) var(--ease-out),
        transform var(--dur-fast) var(--ease-out),
        visibility var(--dur-fast) var(--ease-out);
    }
    .nav.is-open .nav__links {
      visibility: visible;
      opacity: 1;
      transform: translateY(0);
    }

    .nav__list {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }
    .nav__item {
      border-left: none;
      border-top: var(--border);
    }
    .nav__item:first-child {
      border-top: none;
    }
    .nav__link {
      width: 100%;
      min-height: 52px;
      padding-inline: var(--gutter);
      gap: var(--space-3);
      font-size: var(--fs-sm);
    }
    /* keep the index numbers visible in the dropdown — there's room here */
    .nav__index {
      min-width: 1.6em;
    }

    /* open state: morph bars into an X */
    .nav.is-open .nav__toggle-bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }
    .nav.is-open .nav__toggle-bar:nth-child(2) {
      opacity: 0;
    }
    .nav.is-open .nav__toggle-bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  // Mobile hamburger: toggle the dropdown; close it after a link is tapped or
  // when the viewport grows back to desktop. Desktop ignores this entirely.
  const header = document.querySelector<HTMLElement>(".nav");
  const toggle = header?.querySelector<HTMLButtonElement>(".nav__toggle");
  const menu   = header?.querySelector<HTMLElement>(".nav__links");

  if (header && toggle && menu) {
    const setOpen = (open: boolean) => {
      header.classList.toggle("is-open", open);
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    };
    toggle.addEventListener("click", () =>
      setOpen(!header.classList.contains("is-open")));
    menu.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) setOpen(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
    // Reset when crossing back to desktop so the panel never sticks "open".
    const mq = window.matchMedia("(min-width: 861px)");
    mq.addEventListener("change", (e) => { if (e.matches) setOpen(false); });
  }
</script>
