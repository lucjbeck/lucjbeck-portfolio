---
/**
 * Nav — datasheet-style top bar. A mono wordmark cell on the left and a few
 * hairline-divided anchor cells on the right. Not a generic centered sticky bar.
 * Keyboard accessible with visible focus (inherited from global.css).
 */
const links = [
  { href: "#top", label: "Home", index: "00" },
  { href: "#about", label: "About", index: "01" },
  { href: "#education", label: "Education", index: "02" },
  { href: "#engineering", label: "Engineering", index: "03" },
  { href: "#research", label: "Research", index: "04" },
  { href: "#experience", label: "Experience", index: "05" },
  { href: "#contact", label: "Contact", index: "06" },
];
---

<header class="nav">
  <a class="nav__wordmark" href="#top">
    <span class="nav__mark" aria-hidden="true">
      <span class="nav__mark-num">29</span>
      <span class="nav__mark-sym">Lb</span>
      <span class="nav__mark-mass">3.95</span>
    </span>
    <span class="nav__name">Luc Beck</span>
  </a>

  <nav class="nav__links" aria-label="Primary">
    <ul role="list" class="nav__list">
      {
        links.map((link) => (
          <li class="nav__item">
            <a class="nav__link" href={link.href} data-spring>
              <span class="nav__index" aria-hidden="true">{link.index}</span>
              <span class="nav__label">{link.label}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: var(--space-4);
    padding-inline: var(--gutter);
    border-bottom: var(--border);
    background: color-mix(in srgb, var(--c-bg) 86%, transparent);
    backdrop-filter: blur(8px);
  }

  .nav__wordmark {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-3);
    color: var(--c-text);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }
  .nav__wordmark:hover {
    color: var(--c-text);
    text-decoration: none;
  }

  /* periodic-table element tile */
  .nav__mark {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 2.4rem;
    height: 2.4rem;
    border: 1px solid var(--c-hairline-strong);
    border-radius: var(--r-sm);
    background: var(--c-bg-elev);
    overflow: hidden;
  }
  .nav__mark-num {
    position: absolute;
    top: 2px;
    left: 3px;
    font-size: 0.42rem;
    line-height: 1;
    letter-spacing: -0.08em;
    color: var(--c-text-faint);
    font-variant-numeric: tabular-nums;
  }
  .nav__mark-mass {
    position: absolute;
    bottom: 2px;
    right: 3px;
    font-size: 0.42rem;
    line-height: 1;
    letter-spacing: -0.08em;
    color: var(--c-text-faint);
    font-variant-numeric: tabular-nums;
  }
  .nav__mark-sym {
    font-family: var(--font-display);
    font-weight: var(--fw-display);
    font-size: 0.82rem;
    line-height: 1;
    color: var(--c-accent);
    letter-spacing: 0;
    text-transform: none;
  }

  .nav__name {
    color: var(--c-text-muted);
  }

  .nav__links {
    display: flex;
  }

  .nav__list {
    display: flex;
    align-items: stretch;
    margin: 0;
  }

  .nav__item {
    display: flex;
    border-left: var(--border);
  }

  .nav__link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding-inline: var(--space-4);
    color: var(--c-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    transition: color var(--dur-fast) var(--ease-out),
      background var(--dur-fast) var(--ease-out);
  }
  .nav__link:hover {
    color: var(--c-text);
    background: var(--c-bg-elev);
    text-decoration: none;
  }

  .nav__index {
    color: var(--c-accent);
    font-size: var(--fs-micro);
  }

  /* On small screens, hide the index numbers and the descriptive name; keep
     labels usable. */
  @media (max-width: 720px) {
    .nav__name,
    .nav__index {
      display: none;
    }
    .nav__link {
      padding-inline: var(--space-3);
    }
  }

  @media (max-width: 480px) {
    .nav__list {
      flex-wrap: wrap;
      justify-content: flex-end;
    }
  }
</style>
