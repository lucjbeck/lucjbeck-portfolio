---
/**
 * EducationList — a datasheet of rows: each row is a labeled field rendered as
 * a hairline-divided cell pair (mono label + value). The drawn-grid device.
 * The Coursework row renders grouped sub-lists (mono group head + body courses).
 */
const rows = [
  {
    label: "Institution",
    value: "University of Pennsylvania",
    note: "School of Engineering and Applied Science",
  },
  {
    label: "Degree",
    value: "B.S.E., Electrical Engineering and Artificial Intelligence",
    note: "Dual major",
  },
  { label: "GPA", value: "3.95 / 4.00" },
  { label: "Class of", value: "2029" },
  {
    label: "Coursework",
    groups: [
      { head: "Computer Science", items: "Object-Oriented Programming, Scientific Computing" },
      { head: "Mathematics", items: "Linear Algebra, Multivariable Calculus, Discrete Mathematics" },
      { head: "Physics", items: "Mechanics, Electromagnetism" },
      { head: "Economics", items: "Microeconomics, Macroeconomics" },
    ],
  },
  {
    label: "Honors",
    value: "U.S. Presidential Scholar",
    note: "One of up to 161 students named nationally each year",
  },
];
---

<dl class="edu" data-reveal-group="education">
  {
    rows.map((row) => (
      <div class="edu__row" data-reveal>
        <dt class="edu__label">{row.label}</dt>
        <dd class="edu__value">
          {row.groups ? (
            <div class="edu__groups">
              {row.groups.map((g) => (
                <div class="edu__group">
                  <span class="edu__group-head">{g.head}</span>
                  <span class="edu__group-items">{g.items}</span>
                </div>
              ))}
            </div>
          ) : (
            <Fragment>
              <span class="edu__primary">{row.value}</span>
              {row.note && <span class="edu__note">{row.note}</span>}
            </Fragment>
          )}
        </dd>
      </div>
    ))
  }
</dl>

<style>
  .edu {
    margin: 0;
    border: var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
  }

  .edu__row {
    display: grid;
    grid-template-columns: minmax(8rem, 12rem) 1fr;
    border-top: var(--border);
  }
  .edu__row:first-child {
    border-top: none;
  }

  .edu__label {
    padding: var(--space-4) var(--space-5);
    border-right: var(--border);
    background: var(--c-bg-elev);
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }

  .edu__value {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-4) var(--space-5);
    margin: 0;
  }

  .edu__primary {
    color: var(--c-text);
    font-weight: var(--fw-medium);
  }

  .edu__note {
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  /* Coursework groups: mono header + body course list, aligned to the grid. */
  .edu__groups {
    display: grid;
    gap: var(--space-3);
  }
  .edu__group {
    display: grid;
    grid-template-columns: minmax(7rem, 9rem) 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }
  .edu__group-head {
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }
  .edu__group-items {
    color: var(--c-text);
  }

  @media (max-width: 560px) {
    .edu__row {
      grid-template-columns: 1fr;
    }
    .edu__label {
      border-right: none;
      border-bottom: var(--border);
    }
    .edu__group {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
