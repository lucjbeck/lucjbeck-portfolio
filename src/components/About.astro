---
/**
 * About — two columns: text on the left, an assembly animation on the right.
 * On mobile they stack (text first, animation below). The animation (a top-down
 * arm assembling a geometric Penn shield) lives in AboutAssembly.astro.
 */
import EngineeringHero from "./EngineeringHero.astro";
---

<div class="about">
  <div class="about__text" data-reveal>
    <p class="about__label">Premise</p>
    <p class="about__abstract">
      Take a system apart and put it back together until you understand exactly
      how it works. Then build the version that should exist.
    </p>
    <p class="about__lead">
      My interests sit where hard physics meets computational theory. In my
      scientific research, that means biophysics: I built mathematical models of
      how DNA-based polymers can be used to perform experiments (aka "lab on a
      molecule"), which fed into a drug-discovery platform now developing
      therapeutics. Outside scientific research, I build systems that move and
      learn, like a robotic arm I built and taught to manipulate objects via
      imitation learning.
    </p>
    <p class="about__interests">
      I'm also interested in societal problem solving through serial
      entrepreneurship.
    </p>
  </div>

  <figure class="about__stage" data-reveal>
    <EngineeringHero />
    <figcaption class="about__cap">
      <span aria-hidden="true">FIG. 02</span>
      The future of manufacturing: Systems that move, learn, and build.
    </figcaption>
  </figure>
</div>

<style>
  .about {
    display: grid;
    grid-template-columns: minmax(0, 0.45fr) minmax(0, 0.55fr);
    gap: clamp(var(--space-6), 4vw, var(--space-8));
    align-items: start;
  }

  .about__label {
    margin-bottom: var(--space-3);
    color: var(--c-accent);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }
  .about__abstract {
    margin-bottom: var(--space-5);
    max-width: 46ch;
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: var(--lh-mono);
  }
  .about__lead {
    max-width: 52ch;
    font-size: var(--fs-body-l);
    color: var(--c-text);
  }
  .about__interests {
    margin-top: var(--space-4);
    max-width: 52ch;
    color: var(--c-text-faint);
  }

  .about__stage {
    margin: 0;
  }
  .about__cap {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    line-height: var(--lh-mono);
    letter-spacing: 0.04em;
  }
  .about__cap span {
    color: var(--c-accent);
  }

  @media (max-width: 900px) {
    .about {
      grid-template-columns: 1fr;
    }
    .about__stage {
      order: 2;
    }
  }
</style>
