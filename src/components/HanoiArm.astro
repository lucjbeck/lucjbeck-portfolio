---
/**
 * HanoiArm — side-elevation Tower of Hanoi (4 disks) solved correctly by a
 * ceiling-slider arm. Three real poles; rings must be lifted up and clear of a
 * pole's top before moving. The move list comes from the recursive algorithm and
 * peg state is tracked with stacks (top-disk-only, never larger-on-smaller) in
 * ../scripts/hanoi.ts. The arm = a carriage on a ceiling rail (prismatic) + a
 * 2-link IK arm hanging below; rings ride the gripper. Neutral lines, red accent.
 * Plays on scroll-in, loops; reduced-motion shows the solved tower at rest.
 *
 * Mount id: #hanoi. Geometry mirrored in the script.
 */
const VW = 600;
const VH = 460;
const POLEX = [150, 300, 450];
const BASE_Y = 400;     // top of the base bar (rings rest from here up)
const POLE_TOP = 170;
const RH = 28;
const widthOf = (s: number) => [64, 94, 124, 154][s - 1];
const cy = (level: number) => BASE_Y - level * RH - 14;
const start = [4, 3, 2, 1].map((s, i) => ({ s, level: 3 - i })); // 4 bottom ... 1 top
const ticks = Array.from({ length: 9 }, (_, i) => 60 + i * 46);
---

<div id="hanoi" class="hn" role="img" aria-label="A ceiling-mounted robotic arm solving a four-disk Tower of Hanoi on three poles">
  <svg class="hn-svg" viewBox={`0 0 ${VW} ${VH}`} fill="none" aria-hidden="true">
    <rect class="hn-surface" x="20" y="20" width={VW - 40} height={VH - 40} rx="6"></rect>
    {ticks.map((t) => (<line class="hn-grid" x1="20" y1={t} x2={VW - 20} y2={t} />))}

    <!-- ceiling rail (carriage slides along it) -->
    <line class="hn-rail" x1="44" y1="40" x2={VW - 44} y2="40"></line>
    <line class="hn-rail-2" x1="44" y1="44" x2={VW - 44} y2="44"></line>

    <!-- base + three poles -->
    <rect class="hn-base" x="70" y={BASE_Y} width={VW - 140} height="10" rx="3"></rect>
    {POLEX.map((x) => (
      <rect class="hn-pole" x={x - 3.5} y={POLE_TOP} width="7" height={BASE_Y - POLE_TOP + 4} rx="3.5" />
    ))}

    <!-- rings, stacked on the left pole at start -->
    {
      start.map((d) => (
        <rect
          class="hn-disk"
          data-disk
          data-size={d.s}
          x={-widthOf(d.s) / 2}
          y={-13}
          width={widthOf(d.s)}
          height="26"
          rx="9"
          transform={`translate(${POLEX[0]} ${cy(d.level)})`}
        />
      ))
    }

    <!-- carriage on the rail + hanging 2-link arm (rest pivot x = 300) -->
    <g class="hn-carriage" data-carriage transform="translate(0 0)">
      <rect class="hn-cart" x="282" y="32" width="36" height="16" rx="3"></rect>
      <circle class="hn-rollsm" cx="290" cy="40" r="3"></circle>
      <circle class="hn-rollsm" cx="310" cy="40" r="3"></circle>
      <line class="hn-link" data-upper x1="300" y1="52" x2="300" y2="227"></line>
      <line class="hn-link" data-fore x1="300" y1="227" x2="300" y2="397"></line>
      <circle class="hn-joint" cx="300" cy="52" r="7"></circle>
      <circle class="hn-joint" data-elbow cx="300" cy="227" r="6"></circle>
      <g class="hn-grip" data-grip transform="translate(300 397)">
        <circle class="hn-grip-ring" r="9"></circle>
        <line class="hn-grip-jaw" x1="-9" y1="0" x2="-15" y2="0"></line>
        <line class="hn-grip-jaw" x1="9" y1="0" x2="15" y2="0"></line>
      </g>
    </g>
  </svg>
</div>

<style>
  .hn { width: 100%; max-width: 540px; margin-inline: auto; filter: drop-shadow(0 0 26px rgba(230, 57, 70, 0.06)); }
  .hn-svg { width: 100%; height: auto; display: block; }
  .hn-surface { fill: var(--c-bg-elev); stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .hn-grid { stroke: var(--c-hairline); stroke-width: 1; }
  .hn-rail { stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .hn-rail-2 { stroke: var(--c-hairline); stroke-width: 1.5; }
  .hn-base { fill: var(--c-bg-elev-2); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .hn-pole { fill: var(--c-bg-elev-2); stroke: var(--c-text-faint); stroke-width: 1.5; }

  .hn-disk {
    fill: var(--c-bg-elev-2);
    stroke: var(--c-text-muted);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
  }
  .hn-disk.is-active { fill: var(--c-accent-dim); stroke: var(--c-accent); }

  .hn-cart { fill: var(--c-bg-elev-2); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .hn-rollsm { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 1.5; }
  .hn-link { stroke: var(--c-text-muted); stroke-width: 8; stroke-linecap: round; }
  .hn-joint { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 2; }
  .hn-grip-ring { fill: none; stroke: var(--c-text-faint); stroke-width: 2.5; }
  .hn-grip-jaw { stroke: var(--c-text-faint); stroke-width: 2.5; stroke-linecap: round; }
  .hn-grip.is-gripping .hn-grip-ring,
  .hn-grip.is-gripping .hn-grip-jaw { stroke: var(--c-accent); }
</style>

<script>
  import { initHanoi } from "../scripts/hanoi.ts";
  initHanoi();
</script>
