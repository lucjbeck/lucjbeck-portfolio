---
/**
 * HanoiArm — top-down 2-link arm that solves Tower of Hanoi (3 disks) correctly.
 * The move list is generated by the real recursive algorithm and peg state is
 * tracked with stacks (only the top disk moves; never a larger disk onto a
 * smaller one) in ../scripts/hanoi.ts. The arm reaches each target via closed-form
 * 2-link IK; motion uses a spring integrator. Neutral line aesthetic, red accent
 * only. Plays on scroll-in, loops; reduced-motion shows the solved state at rest.
 *
 * Mount id: #hanoi. Geometry mirrored in the script.
 */
const VB = 600;
const pegX = [150, 300, 450];
const BASE_Y = 470;
const DH = 36;
// start stack on the left peg: large (3) bottom, then 2, then 1 on top
const startDisks = [
  { size: 3, level: 0 },
  { size: 2, level: 1 },
  { size: 1, level: 2 },
];
const widthOf = (s: number) => (s === 1 ? 72 : s === 2 ? 108 : 144);
const cy = (level: number) => BASE_Y - level * DH - 18;
const ticks = Array.from({ length: 9 }, (_, i) => 60 + i * 60);
---

<div id="hanoi" class="hn" role="img" aria-label="A robotic arm solving the Tower of Hanoi puzzle with three disks">
  <svg class="hn-svg" viewBox={`0 0 ${VB} ${VB}`} fill="none" aria-hidden="true">
    <rect class="hn-surface" x="20" y="20" width="560" height="560" rx="6"></rect>
    {ticks.map((t) => (
      <g class="hn-grid"><line x1={t} y1="20" x2={t} y2="580" /><line x1="20" y1={t} x2="580" y2={t} /></g>
    ))}

    <!-- peg base zones -->
    {pegX.map((x) => (
      <line class="hn-peg" x1={x - 84} y1={BASE_Y + 14} x2={x + 84} y2={BASE_Y + 14} />
    ))}

    <!-- disks (start stacked on the left peg; the script drives them) -->
    {
      startDisks.map((d) => (
        <rect
          class="hn-disk"
          data-disk
          data-size={d.size}
          x={-widthOf(d.size) / 2}
          y={-15}
          width={widthOf(d.size)}
          height={30}
          rx="8"
          transform={`translate(${pegX[0]} ${cy(d.level)})`}
        />
      ))
    }

    <!-- top-down 2-link arm, base at the bottom edge -->
    <g class="hn-arm" data-arm>
      <line class="hn-link" data-upper x1="300" y1="600" x2="300" y2="410"></line>
      <line class="hn-link" data-fore x1="300" y1="410" x2="300" y2="230"></line>
      <circle class="hn-joint" cx="300" cy="600" r="11"></circle>
      <circle class="hn-joint" data-elbow cx="300" cy="410" r="8"></circle>
      <g class="hn-grip" data-grip transform="translate(300 230)">
        <circle class="hn-grip-ring" r="10"></circle>
        <line class="hn-grip-jaw" x1="-10" y1="0" x2="-16" y2="0"></line>
        <line class="hn-grip-jaw" x1="10" y1="0" x2="16" y2="0"></line>
      </g>
    </g>
  </svg>
</div>

<style>
  .hn { width: 100%; max-width: 520px; margin-inline: auto; filter: drop-shadow(0 0 26px rgba(230, 57, 70, 0.06)); }
  .hn-svg { width: 100%; height: auto; display: block; }
  .hn-surface { fill: var(--c-bg-elev); stroke: var(--c-hairline-strong); stroke-width: 1.5; }
  .hn-grid line { stroke: var(--c-hairline); stroke-width: 1; }
  .hn-peg { stroke: var(--c-text-faint); stroke-width: 2; stroke-linecap: round; }

  .hn-disk {
    fill: var(--c-bg-elev-2);
    stroke: var(--c-text-muted);
    stroke-width: 1.5;
    transform-box: fill-box;
    transform-origin: center;
  }
  .hn-disk.is-active {
    fill: var(--c-accent-dim);
    stroke: var(--c-accent);
  }

  .hn-link { stroke: var(--c-text-muted); stroke-width: 9; stroke-linecap: round; }
  .hn-joint { fill: var(--c-bg); stroke: var(--c-text-faint); stroke-width: 2; }
  .hn-grip-ring { fill: none; stroke: var(--c-text-faint); stroke-width: 2.5; }
  .hn-grip-jaw { stroke: var(--c-text-faint); stroke-width: 2.5; stroke-linecap: round; }
  .hn-grip.is-gripping .hn-grip-ring,
  .hn-grip.is-gripping .hn-grip-jaw { stroke: var(--c-accent); }
</style>

<script>
  import { initHanoi } from "../scripts/hanoi.ts";
  initHanoi();
</script>
