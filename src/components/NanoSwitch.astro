---
/**
 * NanoSwitch.astro — physics-simulated DNA nanoswitch (Research section).
 * The backbone is a flexible polymer: a chain of point masses with distance
 * constraints, jiggling in solution under thermal noise (Verlet integration in
 * ../scripts/nanoswitch.ts). It carries two biotins. Streptavidin analytes drift
 * in solution; each cycle one binds a biotin, a binding spring folds the whole
 * strand into a loop so the analyte bridges the second biotin, then it releases
 * and the chain relaxes. Autonomous, continuous.
 *
 * The script draws the backbone `d` and positions biotins/analytes itself every
 * frame (own rAF, not anime tweening). SSR renders a static relaxed strand so
 * reduced-motion / no-JS users get a correct figure.
 *
 * Mount id: #nanoswitch. Geometry constants below are mirrored in the script.
 */
const VW = 460;
const VH = 240;
const N = 20; // backbone nodes
const X0 = 58;
const X1 = 402;
const BASE_Y = 122;
const SITE_A = 6; // biotin node indices
const SITE_B = 13;

const nodes = Array.from({ length: N }, (_, i) => {
  const x = X0 + ((X1 - X0) * i) / (N - 1);
  const y = BASE_Y + 9 * Math.sin(i * 0.6);
  return { x: Math.round(x * 10) / 10, y: Math.round(y * 10) / 10 };
});
const ssrPath = "M" + nodes.map((p) => `${p.x},${p.y}`).join(" L");

const analytes = [
  { x: 84, y: 54 },
  { x: 384, y: 64 },
  { x: 126, y: 34 },
  { x: 360, y: 168 },
  { x: 230, y: 40 },
  { x: 300, y: 196 },
];
---

<div
  id="nanoswitch"
  class="nanoswitch"
  data-n={N}
  data-x0={X0}
  data-x1={X1}
  data-base-y={BASE_Y}
  data-site-a={SITE_A}
  data-site-b={SITE_B}
  role="img"
  aria-label="DNA nanoswitch simulated as a flexible polymer: a jiggling strand with two biotins and streptavidin analytes in solution; an analyte binds a biotin, the strand folds into a loop to bridge the second, then releases"
>
  <svg class="ns-svg" viewBox={`0 0 ${VW} ${VH}`} fill="none" aria-hidden="true">
    <!-- flexible backbone (the polymer); d is rewritten each frame -->
    <path class="ns-strand" data-strand d={ssrPath}></path>

    <!-- biotins, positioned at their backbone nodes each frame -->
    <g class="ns-biotin" data-biotin transform={`translate(${nodes[SITE_A].x} ${nodes[SITE_A].y})`}>
      <polygon points="0,-8 8,0 0,8 -8,0"></polygon>
    </g>
    <g class="ns-biotin" data-biotin transform={`translate(${nodes[SITE_B].x} ${nodes[SITE_B].y})`}>
      <polygon points="0,-8 8,0 0,8 -8,0"></polygon>
    </g>

    <!-- streptavidin analytes (the accent X); one engages per cycle -->
    {
      analytes.map((a) => (
        <g class="ns-analyte" data-analyte data-fx={a.x} data-fy={a.y} transform={`translate(${a.x} ${a.y})`}>
          <line class="ns-x" x1="-8" y1="-8" x2="8" y2="8" />
          <line class="ns-x" x1="8" y1="-8" x2="-8" y2="8" />
        </g>
      ))
    }
  </svg>

  <ul class="ns-legend" aria-hidden="true">
    <li><span class="ns-key ns-key--biotin"></span>Biotin</li>
    <li><span class="ns-key ns-key--strept"></span>Streptavidin</li>
    <li><span class="ns-key ns-key--strand"></span>DNA backbone</li>
  </ul>
</div>

<style>
  .nanoswitch {
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
    filter: drop-shadow(0 0 26px rgba(230, 57, 70, 0.08));
  }
  .ns-svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .ns-strand {
    stroke: var(--c-text-faint);
    stroke-width: 4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ns-biotin polygon {
    fill: var(--c-bg-elev-2);
    stroke: var(--c-text-muted);
    stroke-width: 1.5;
  }

  .ns-analyte {
    transform-box: fill-box;
    transform-origin: center;
  }
  .ns-x {
    stroke: var(--c-accent);
    stroke-width: 4.5;
    stroke-linecap: round;
  }

  .ns-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    margin: var(--space-5) 0 0;
    padding: 0;
    list-style: none;
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
    color: var(--c-text-faint);
  }
  .ns-legend li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }
  .ns-key {
    width: 12px;
    height: 12px;
    display: inline-block;
  }
  .ns-key--biotin {
    background: var(--c-bg-elev-2);
    border: 1.5px solid var(--c-text-muted);
    transform: rotate(45deg);
  }
  .ns-key--strept {
    background: var(--c-accent);
  }
  .ns-key--strand {
    border-top: 4px solid var(--c-text-faint);
    height: 0;
    align-self: center;
  }
</style>

<script>
  import { initNanoSwitch } from "../scripts/nanoswitch.ts";
  initNanoSwitch();
</script>
