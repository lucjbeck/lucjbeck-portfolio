---
/**
 * index.astro — Luc Beck portfolio home (single long editorial page).
 * Assembles: Nav, Hero (mounts NanoSwitch), then the catalogued sections, then
 * the contact footer. Catalog numbering is the structural spine: nav indices
 * number the sections; entry tags (FIG./SPEC./ROLE.) number the specimens.
 * All copy is verbatim from the brief. Placeholders are flagged in markup.
 */
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import About from "../components/About.astro";
import EducationList from "../components/EducationList.astro";
import ProjectEntry from "../components/ProjectEntry.astro";
import RobotArm from "../components/RobotArm.astro";
import ResearchEntry from "../components/ResearchEntry.astro";
import NanoSwitch from "../components/NanoSwitch.astro";
import Publication from "../components/Publication.astro";
import RoleEntry from "../components/RoleEntry.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Base>
  <a class="skip-link" href="#main">Skip to content</a>
  <Nav />

  <main id="main">
    <Hero />

    <Section id="about" eyebrow="00" heading="About">
      <About />
    </Section>

    <Section id="education" eyebrow="01" heading="Education" rule>
      <EducationList />
    </Section>

    <Section id="engineering" eyebrow="02" heading="Engineering" rule>
      <figure class="section-figure" data-reveal>
        <RobotArm />
        <figcaption>
          <span aria-hidden="true">FIG. 01a</span>
          Two-link arm, pick-and-place cycle.
        </figcaption>
      </figure>

      <ProjectEntry
        tag="FIG. 01"
        title="Robotic Arm + ACT Policy"
        specs={[
          { label: "Capability", value: "[PLACEHOLDER]", placeholder: true },
          { label: "Demo", value: "[PLACEHOLDER]", placeholder: true },
          { label: "Code", value: "[PLACEHOLDER]", placeholder: true },
        ]}
      >
        <p>
          Built a robotic arm and trained an action-chunking-with-transformers
          (ACT) policy on it using Hugging Face / LeRobot.
        </p>
      </ProjectEntry>
    </Section>

    <Section id="research" eyebrow="03" heading="Research" rule>
      <div class="research-split">
      <figure class="section-figure research-split__fig" data-reveal>
        <NanoSwitch />
        <figcaption>
          <span aria-hidden="true">FIG. 02</span>
          DNA nanoswitch, simulated as a flexible polymer. A streptavidin
          analyte binds a biotin, the strand loops to bridge the second, then
          releases.
        </figcaption>
      </figure>

      <div class="research-split__text">
      <ResearchEntry
        tag="SPEC-01"
        title="DNA Nanoswitches for Drug Discovery"
        org="Wong Lab, Wyss Institute / Boston Children's Hospital / Harvard"
        period="2023 to 2025"
      >
        <p>
          Three summers building a DNA-nanoswitch platform for therapeutic
          discovery. I derived polymer-physics and enzyme-kinetic models
          predicting nanoswitch conformational states, reaction rates, and
          binding equilibria, and used AlphaFold and Python to model
          nanobody-target interactions across autoimmune and viral pathways. I
          ran native PAGE gel-shift assays measuring binding enhancement of
          nanoswitch-discovered nanobodies on the PD-1/PD-L1 complex implicated
          in autoimmune disease. The platform has since spun into a company
          developing therapeutics, with candidates advancing toward clinical
          trials.
        </p>

        <p class="research-abstract" data-reveal>
          <span class="research-abstract__label" aria-hidden="true">Abstract, JEI</span>
          This paper investigates how spatial constraints influence molecular
          binding by using DNA nanoswitches, programmable DNA scaffolds that
          position binding partners at defined distances. By integrating
          gel-based experiments with a polymer physics model, we quantify how
          binding-site arrangement affects the probability of loop formation
          through changes in effective local concentration. The results provide a
          generalizable approach for predicting and controlling tethered
          biomolecular interactions in synthetic and biological systems.
        </p>

        <Fragment slot="publications">
          <Publication
            role="First author"
            venue="Journal of Emerging Investigators"
            placeholder={true}
          >
            Tethered Molecular Interactions in DNA Nanoswitches: Modeling and
            Controlling Local Concentration. With Harvard Medical School
            professor Wesley Wong.
          </Publication>
        </Fragment>
      </ResearchEntry>
      </div>
      </div>
    </Section>

    <Section id="experience" eyebrow="04" heading="Experience" rule>
      <div class="roles">
        <RoleEntry
          tag="ROLE-01"
          firm="Northpond Ventures"
          role="Venture Capital Intern"
          term="Summers 2024 and 2025"
          location="Cambridge, MA"
        >
          <p>
            Northpond is a science-driven venture firm backing companies across
            life sciences, healthcare, and deep technology. I evaluated the
            spin-out of DNA-nanoswitch drug-discovery technology into a new
            company, Merge Bio, analyzing platform scalability, IP positioning,
            and commercialization strategy. I built the financial model,
            including a risk-adjusted revenue build, DCF, and sensitivity
            analyses that integrated market sizing, pricing benchmarks, and
            probability-of-success adjustments across clinical phases. I authored
            scientific positioning on nanoswitch-based therapies for Type 1
            Diabetes, covering PD-1/PD-L1 agonist mechanisms, nanobody
            properties, and the competitive landscape. The work fed into a $15M
            seed round.
          </p>
        </RoleEntry>

        <RoleEntry
          tag="ROLE-02"
          firm="Construct Capital"
          term="Summer 2025"
        >
          <p>
            Construct is an early-stage venture firm investing in companies that
            transform the foundational industries of the economy, including
            manufacturing, logistics, supply chain, transportation, and defense.
            I built AI agent infrastructure that streamlines the firm's internal
            workflows and the screening of inbound companies, accelerating them
            through the deal pipeline.
          </p>
        </RoleEntry>
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>

<style>
  /* Accessible skip link: hidden until focused. */
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: var(--space-4);
    z-index: calc(var(--z-nav) + 10);
    padding: var(--space-2) var(--space-4);
    background: var(--c-bg-elev-2);
    border: var(--border-strong);
    border-radius: var(--r-md);
    color: var(--c-text);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    transform: translateY(-200%);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .skip-link:focus-visible {
    transform: translateY(0);
  }

  /* Two role entries share a hairline-joined stack. */
  .roles {
    display: grid;
    gap: var(--space-6);
  }

  /* Section figures (the robot arm, the nanoswitch) sit above their entries. */
  .section-figure {
    margin: 0 0 var(--space-7);
    padding: var(--space-6);
    border: var(--border);
    border-radius: var(--r-md);
    background: var(--c-bg-elev);
  }
  .section-figure figcaption {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    max-width: 60ch;
    margin-top: var(--space-4);
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    line-height: var(--lh-mono);
    letter-spacing: 0.04em;
  }
  .section-figure figcaption span {
    color: var(--c-accent);
  }

  /* Nanoswitch figure side-by-side with the research text. */
  .research-split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(var(--space-5), 3vw, var(--space-8));
    align-items: start;
  }
  .research-split__fig {
    margin: 0;
    position: sticky;
    top: 92px;
  }
  .research-split__text { min-width: 0; }
  @media (max-width: 900px) {
    .research-split { grid-template-columns: 1fr; }
    .research-split__fig { position: static; }
  }

  .research-abstract {
    margin-top: var(--space-5);
    padding-left: var(--space-5);
    border-left: 2px solid var(--c-accent-dim);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }
  .research-abstract__label {
    display: block;
    margin-bottom: var(--space-2);
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    letter-spacing: var(--ls-label);
    text-transform: uppercase;
  }
</style>

<script>
  // Scroll-reveal + spring micro-interactions (self-init by scanning their
  // data-attributes; see design/ANIMATION-NOTES.md for the contract).
  import "../scripts/reveal.ts";
  import "../scripts/micro.ts";
</script>
