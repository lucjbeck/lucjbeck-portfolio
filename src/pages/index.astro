---
/**
 * index.astro — Luc Beck portfolio home (single long editorial page).
 * Assembles: Nav, Hero (mounts NanoSwitch), then the catalogued sections, then
 * the contact footer. Catalog numbering is the structural spine: nav indices
 * number the sections; entry tags (FIG./SPEC./ROLE.) number the specimens.
 * All copy is verbatim from the brief. Placeholders are flagged in markup.
 */
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import Section from "../components/Section.astro";
import About from "../components/About.astro";
import EducationList from "../components/EducationList.astro";
import ProjectEntry from "../components/ProjectEntry.astro";
import HanoiArm from "../components/HanoiArm.astro";
import ResearchEntry from "../components/ResearchEntry.astro";
import NanoSwitch from "../components/NanoSwitch.astro";
import Publication from "../components/Publication.astro";
import RoleEntry from "../components/RoleEntry.astro";
import HandAnimation from "../components/HandAnimation.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Base>
  <a class="skip-link" href="#main">Skip to content</a>
  <Nav />

  <main id="main">
    <Hero />

    <Section id="about" eyebrow="01" heading="About">
      <About />
    </Section>

    <Section id="education" eyebrow="02" heading="Education" rule>
      <div class="edu-split">
        <div class="edu-split__list" data-reveal>
          <EducationList />
        </div>
        <figure class="edu-split__fig" data-reveal>
          <HanoiArm />
          <figcaption class="split__cap">
            <span aria-hidden="true">FIG. 03</span>
            Tower of Hanoi, 4 disks, recursive solution.
          </figcaption>
        </figure>
      </div>
    </Section>

    <Section id="engineering" eyebrow="03" heading="Engineering" rule>
      <div class="eng-split">
        <div class="eng-split__projects">
          <div class="projects" data-reveal>
            <ProjectEntry
              tag="PROJ-01"
              title="Robotic Arm + ACT Policy"
              specs={[
                { label: "Demo", value: "x.com/lucjbeck", href: "https://x.com/lucjbeck" },
              ]}
            >
              <p>
                Building a robotic arm and training an action-chunking-with-transformers
                (ACT) policy on it using Hugging Face / LeRobot. Still a work in progress.
              </p>
            </ProjectEntry>

            <ProjectEntry
              tag="PROJ-02"
              title="Next: Robotic Hand"
            >
              <p>
                Building a dexterous robotic hand paired with an instrumented glove.
                The glove captures human hand motion so the robot can be trained
                directly on teleoperated demonstrations, giving it a path to develop
                the fine-grained manipulation that standard robot arms lack.
              </p>
            </ProjectEntry>
          </div>
        </div>

        <figure class="eng-split__fig" data-reveal>
          <HandAnimation />
          <figcaption class="split__cap">
            <span aria-hidden="true">FIG. 05</span>
            Teleoperation training loop: human glove drives the demo hand; the
            policy hand learns to match. Motor positions stream to the graph below.
          </figcaption>
        </figure>
      </div>
    </Section>

    <Section id="research" eyebrow="04" heading="Research" rule>
      <div class="research-split">
      <div class="research-split__text">
      <ResearchEntry
        tag="SPEC-01"
        title="DNA Nanoswitches for Drug Discovery"
        org="Wong Lab, Wyss Institute / Boston Children's Hospital / Harvard"
        period="2023 to 2025"
      >
        <p>
          Three summers building a DNA-nanoswitch platform for therapeutic
          discovery. I derived polymer-physics and enzyme-kinetic models
          predicting nanoswitch conformational states, reaction rates, and
          binding equilibria, and used AlphaFold and Python to model
          nanobody-target interactions across autoimmune and viral pathways. I
          ran native PAGE gel-shift assays measuring binding enhancement of
          nanoswitch-discovered nanobodies on the PD-1/PD-L1 complex implicated
          in autoimmune disease. The platform has since spun into a company
          developing therapeutics, with candidates advancing toward clinical
          trials.
        </p>

        <Fragment slot="publications">
          <Publication
            role="First author"
            venue="Journal of Emerging Investigators"
            status="Accepted — Awaiting Publication"
            abstract="This paper investigates how spatial constraints influence molecular binding by using DNA nanoswitches, programmable DNA scaffolds that position binding partners at defined distances. By integrating gel-based experiments with a polymer physics model, we quantify how binding-site arrangement affects the probability of loop formation through changes in effective local concentration. The results provide a generalizable approach for predicting and controlling tethered biomolecular interactions in synthetic and biological systems."
          >
            Tethered Molecular Interactions in DNA Nanoswitches: Modeling and
            Controlling Local Concentration. With Wesley Wong (Harvard Medical
            School) and postdoctoral researcher Andy Ward.
          </Publication>
        </Fragment>
      </ResearchEntry>
      </div>

      <figure class="section-figure research-split__fig" data-reveal>
        <NanoSwitch />
        <figcaption>
          <span aria-hidden="true">FIG. 04</span>
          DNA nanoswitch, simulated as a flexible polymer. A streptavidin
          analyte binds a biotin, the strand loops to bridge the second, then
          releases.
        </figcaption>
      </figure>
      </div>
    </Section>

    <Section id="experience" eyebrow="05" heading="Experience" rule>
      <div class="roles">
        <RoleEntry
          firm="Construct Capital"
          role="Summer Analyst"
          term="Summer 2026"
          location="Washington, DC"
        >
          <p>
            I'm building AI agent infrastructure that streamlines the firm's
            internal workflows and the screening of inbound companies,
            accelerating deals through the pipeline.
          </p>
        </RoleEntry>

        <RoleEntry
          firm="Northpond Ventures"
          role="Venture Capital Intern"
          term="Summers 2024 and 2025"
          location="Cambridge, MA"
        >
          <p>
            I evaluated spinning DNA-nanoswitch drug-discovery technology out
            into a new company, Merge Bio, assessing platform scalability, IP
            positioning, and commercialization strategy. I built the financial
            model end to end, a risk-adjusted revenue build, DCF, and sensitivity
            analyses spanning market sizing, pricing benchmarks, and
            probability-of-success adjustments across clinical phases. I also
            authored the scientific positioning on nanoswitch-based therapies for
            Type 1 Diabetes, covering PD-1/PD-L1 agonist mechanisms and the
            competitive landscape. The work fed into a $15M seed round.
          </p>
        </RoleEntry>
      </div>
    </Section>
  </main>

  <SiteFooter />
</Base>

<style>
  /* Accessible skip link: hidden until focused. */
  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: var(--space-4);
    z-index: calc(var(--z-nav) + 10);
    padding: var(--space-2) var(--space-4);
    background: var(--c-bg-elev-2);
    border: var(--border-strong);
    border-radius: var(--r-md);
    color: var(--c-text);
    font-family: var(--font-mono);
    font-size: var(--fs-mono-label);
    transform: translateY(-200%);
    transition: transform var(--dur-fast) var(--ease-out);
  }
  .skip-link:focus-visible {
    transform: translateY(0);
  }

  /* Two role entries share a hairline-joined stack. */
  .roles {
    display: grid;
    gap: var(--space-6);
  }

  /* Section figures (the robot arm, the nanoswitch) sit above their entries. */
  .section-figure {
    margin: 0 0 var(--space-7);
    padding: var(--space-6);
    border: var(--border);
    border-radius: var(--r-md);
    background: var(--c-bg-elev);
  }
  .section-figure figcaption {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    max-width: 60ch;
    margin-top: var(--space-4);
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    line-height: var(--lh-mono);
    letter-spacing: 0.04em;
  }
  .section-figure figcaption span {
    color: var(--c-accent);
  }

  /* Education: list left, Hanoi figure sticky-right. Equal columns so the
     education value cells don't have excess blank space for short entries. */
  .edu-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(var(--space-6), 4vw, var(--space-8));
    align-items: stretch;
  }
  .edu-split__list { min-width: 0; }
  .edu-split__fig {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-6);
    border: var(--border);
    border-radius: var(--r-md);
    background: var(--c-bg-elev);
  }
  .split__cap {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
    color: var(--c-text-faint);
    font-family: var(--font-mono);
    font-size: var(--fs-micro);
    line-height: var(--lh-mono);
    letter-spacing: 0.04em;
  }
  .split__cap span { color: var(--c-accent); }
  @media (max-width: 900px) {
    .edu-split { grid-template-columns: 1fr; }
    .edu-split__fig { order: -1; }
  }

  /* Engineering: projects left, hand animation figure right. */
  .eng-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: clamp(var(--space-6), 4vw, var(--space-8));
    align-items: start;
  }
  .eng-split__projects { min-width: 0; }
  .eng-split__fig {
    margin: 0;
    position: sticky;
    top: 92px;
  }
  @media (max-width: 900px) {
    .eng-split { grid-template-columns: 1fr; }
    .eng-split__fig { position: static; order: -1; }
  }

  /* Stacked project entries within the left column. */
  .projects {
    display: grid;
    gap: var(--space-6);
  }

  /* Nanoswitch figure side-by-side with the research text. */
  .research-split {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(var(--space-5), 3vw, var(--space-8));
    align-items: start;
  }
  .research-split__text { min-width: 0; }
  .research-split__fig {
    margin: 0;
    position: sticky;
    top: 92px;
  }
  @media (max-width: 900px) {
    .research-split { grid-template-columns: 1fr; }
    .research-split__fig { position: static; }
  }

</style>

<script>
  // Scroll-reveal + spring micro-interactions (self-init by scanning their
  // data-attributes; see design/ANIMATION-NOTES.md for the contract).
  import "../scripts/reveal.ts";
  import "../scripts/micro.ts";
</script>
